# Chaves públicas do projeto Supabase. Nunca use a service role em NEXT_PUBLIC_*.
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=SUA_CHAVE_PUBLICA_ANON
NEXT_PUBLIC_SITE_URL=https://seu-dominio.com.br

# Edição comercial segura por padrão: prontuário e áudio ficam desativados.
# Ative somente se houver governança LGPD específica para dados de pacientes.
NEXT_PUBLIC_RESIBOOK_ENABLE_PATIENT_RECORDS=false
NEXT_PUBLIC_RESIBOOK_ENABLE_CLINICAL_AUDIO=false

# Somente servidor. Configure diretamente na Vercel; não grave valor real aqui.
SUPABASE_SERVICE_ROLE_KEY=

# Assinaturas Mercado Pago. Configure somente no servidor da Vercel.
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=

# Credenciais isoladas do vendedor/comprador de teste do Mercado Pago.
# Nunca reutilize credenciais ou e-mail da conta real nestes campos.
MERCADO_PAGO_TEST_ACCESS_TOKEN=
MERCADO_PAGO_TEST_WEBHOOK_SECRET=
MERCADO_PAGO_TEST_PAYER_EMAIL=
RESIBOOK_BILLING_TEST_MODE=false

# Ative somente depois de aplicar a migration de billing e testar o checkout.
RESIBOOK_ENFORCE_SUBSCRIPTIONS=false
